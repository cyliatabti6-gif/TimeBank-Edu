# Copier vers .env et adapter

DJANGO_SECRET_KEY=changez-moi-en-production
DJANGO_DEBUG=True

# Base de données : laisser vide ou sqlite pour fichier local db.sqlite3
# MySQL :
# DATABASE_ENGINE=django.db.backends.mysql
# DATABASE_NAME=timebank_edu
# DATABASE_USER=root
# DATABASE_PASSWORD=
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=3306

# Domaines email universitaires acceptés à l'inscription (séparés par des virgules).
# Vide = tous les domaines acceptés (pratique en dev).
UNIVERSITY_EMAIL_DOMAINS=

# Frontend React (CORS)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
